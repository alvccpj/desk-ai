SECRET_KEY=django-insecure-troque-esta-chave-em-producao
DEBUG=True

# Local: deixe vazio para usar SQLite (padrão).
# Produção (Render) ou Postgres local: cole a URL completa.
# Exemplo local: postgres://usuario:senha@127.0.0.1:5432/desk_ai
# DATABASE_URL=

# Obrigatório com DATABASE_URL no Render; para Postgres local sem SSL: DATABASE_SSL_REQUIRE=false
DATABASE_SSL_REQUIRE=true

# Produção: origens do frontend (separadas por vírgula)
# CORS_ALLOWED_ORIGINS=https://seu-app.vercel.app

# Produção: URL HTTPS do próprio backend (admin / CSRF)
# CSRF_TRUSTED_ORIGINS=https://desk-ai-api.onrender.com

GEMINI_API_KEY=
