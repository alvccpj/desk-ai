SECRET_KEY=django-insecure-troque-esta-chave-em-producao
DEBUG=True

# Deixe vazio para SQLite (padrão em desenvolvimento local).
# Para PostgreSQL: cole a URL completa.
# Exemplo: postgres://usuario:senha@127.0.0.1:5432/desk_ai
# DATABASE_URL=

# Com PostgreSQL: em geral true; para Postgres local sem SSL: DATABASE_SSL_REQUIRE=false
DATABASE_SSL_REQUIRE=true

# Se o front e o back estiverem em origens diferentes, defina (separado por vírgula)
# CORS_ALLOWED_ORIGINS=https://exemplo-frontend

# URL(s) do próprio backend (admin / CSRF), se necessário
# CSRF_TRUSTED_ORIGINS=https://exemplo-api

GEMINI_API_KEY=
# Opcional: modelo Gemini (padrão gemini-2.5-flash). Ver https://ai.google.dev/gemini-api/docs/models
# GEMINI_MODEL=gemini-2.5-flash
